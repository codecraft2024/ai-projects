<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GhostTalk" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ghost_purple</item>
        <item name="colorPrimaryVariant">@color/ghost_purple_dark</item>
        <item name="colorOnPrimary">@color/ghost_text_primary</item>
        <item name="colorSecondary">@color/ghost_purple_light</item>
        <item name="colorOnSecondary">@color/ghost_text_primary</item>
        <item name="android:colorBackground">@color/ghost_background</item>
        <item name="colorSurface">@color/ghost_surface</item>
        <item name="colorOnSurface">@color/ghost_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/ghost_text_secondary</item>
        <item name="colorError">@color/ghost_error</item>
        <item name="android:statusBarColor">@color/ghost_background</item>
        <item name="android:navigationBarColor">@color/ghost_background</item>
        <item name="materialButtonStyle">@style/GhostButton</item>
        <item name="textInputStyle">@style/GhostTextInput</item>
    </style>

    <style name="Theme.GhostTalk.Splash" parent="Theme.GhostTalk">
        <item name="android:windowBackground">@color/ghost_background</item>
    </style>

    <style name="GhostButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/ghost_purple</item>
        <item name="android:textColor">@color/ghost_on_primary</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <style name="GhostButton.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/ghost_purple</item>
        <item name="android:textColor">@color/ghost_purple</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <style name="GhostTextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/ghost_purple</item>
        <item name="hintTextColor">@color/ghost_text_hint</item>
        <item name="boxBackgroundColor">@color/ghost_input_bg</item>
    </style>

    <style name="GhostToolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/ghost_surface</item>
        <item name="titleTextColor">@color/ghost_text_primary</item>
    </style>
</resources>
