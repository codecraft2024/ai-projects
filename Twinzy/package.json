{
  "name": "twinzy",
  "version": "0.1.0",
  "private": true,
  "description": "Celebrity lookalike search with rich profile similarity",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:frontend": "pnpm --filter @twinzy/frontend dev",
    "dev:backend": "cd backend && mvn spring-boot:run -Dspring-boot.run.jvmArguments=-Xmx2g",
    "build": "pnpm --filter @twinzy/frontend build && cd backend && mvn -q package -DskipTests",
    "lint": "pnpm --filter @twinzy/frontend lint",
    "typecheck": "pnpm --filter @twinzy/frontend typecheck",
    "seed": "cd backend && mvn -q spring-boot:run -Dspring-boot.run.profiles=seed -Dspring-boot.run.jvmArguments=-Xmx2g",
    "seed:small": "cd backend && TWINZY_SEED_TOTAL=500 mvn -q spring-boot:run -Dspring-boot.run.profiles=seed -Dspring-boot.run.jvmArguments=-Xmx1g",
    "setup": "pnpm install && pnpm seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
