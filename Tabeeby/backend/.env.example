# Spring profile (use prod in Docker/production)
SPRING_PROFILES_ACTIVE=dev

# HTTP port
SERVER_PORT=8080

# Browser origin allowed to call /api/** (repeat index for multiple origins)
TABEEBY_CORS_ALLOWED_ORIGINS_0=http://localhost:3000

# Local file upload directory
TABEEBY_UPLOAD_DIR=./uploads

# PostgreSQL (default datasource)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tabeeby
POSTGRES_USER=tabeeby
POSTGRES_PASSWORD=tabeeby
