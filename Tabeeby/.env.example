# Copy to .env and adjust for your environment
# cp .env.example .env

# Public URLs (browser-facing — used for CORS and Next.js build-time metadata)
FRONTEND_PUBLIC_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:8080

# Host port mappings
FRONTEND_PORT=3000
BACKEND_PORT=8080

# PostgreSQL (used by backend in Docker)
POSTGRES_DB=tabeeby
POSTGRES_USER=tabeeby
POSTGRES_PASSWORD=tabeeby

# Docker Hub image prefix (optional, for push commands)
# DOCKERHUB_USER=yourusername
