# Backend URL used by Next.js server-side proxy (not exposed to browser)
BACKEND_INTERNAL_URL=http://localhost:8080

# Public site URL for Open Graph previews and share links (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend API base URL (server-side fallback; browser uses /api-proxy)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Optional analytics (leave empty to disable)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
